# Contact form email delivery (Resend). Copy to .env.local and fill in.
# Get an API key at https://resend.com — the form fails politely until this is set.
RESEND_API_KEY=

# Where contact-form messages are delivered. Defaults to the site's contact email.
CONTACT_TO_EMAIL=info@vivabotiks.co.uk

# Sender address. Must be on a domain verified in Resend;
# "Vivabotiks <onboarding@resend.dev>" works before the domain is verified.
CONTACT_FROM_EMAIL=Vivabotiks <onboarding@resend.dev>
